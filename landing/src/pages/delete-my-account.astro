---
import Layout from '../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
let error = null;
let success = false;

if (Astro.request.method === 'POST' && Astro.url.searchParams.has('confirm')) {
    if (!session) {
        error = "You must be signed in to delete your account.";
    } else {
        const serverUrl = process.env.services__server__http__0 || process.env.SERVICES__SERVER__HTTP__0 || import.meta.env.services__server__http__0 || import.meta.env.SERVICES__SERVER__HTTP__0;
        
        if (!serverUrl) {
            error = "Server URL not configured. Please contact support.";
        } else {
            try {
                // @ts-ignore - accessToken is added in auth.config.mjs
                const accessToken = session.accessToken;
                const response = await fetch(`${serverUrl}/api/user/me`, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${accessToken}`
                    }
                });

                if (response.ok || response.status === 204) {
                    success = true;
                } else {
                    const data = await response.text();
                    error = `Failed to delete account: ${data || response.statusText}`;
                }
            } catch (e: any) {
                error = `Error connecting to the server: ${e.message}`;
            }
        }
    }
}
---

<Layout title="Delete My Account">
	<div class="container policy-container">
		<div class="policy-header">
			<h1>Delete My Account</h1>
			<p class="subtitle">Permanently remove your data and Auth0 account.</p>
		</div>
		
		<div class="policy-content">
			{success ? (
				<div class="success-box">
					<h2>Account Successfully Deleted</h2>
					<p>Your account and all associated data have been permanently removed from our systems. You have been logged out.</p>
					<a href="/" class="btn btn-primary">Return to Home</a>
				</div>
			) : (
				<>
					<section class="warning-box">
						<h2>⚠️ Warning: This action is permanent</h2>
						<p>Deleting your account will result in the immediate and irreversible removal of:</p>
						<ul>
							<li>Your store profile and settings.</li>
							<li>All product inventory and pricing data.</li>
							<li>Your visual shelf maps and store layout.</li>
							<li>Any uploaded product images.</li>
							<li>Access to your account via Auth0.</li>
						</ul>
						<p>This action cannot be undone. All data will be purged from our active databases.</p>
					</section>

					<section class="action-section">
						<h2>Delete Your Account Now</h2>
						{error && <p class="error-message">{error}</p>}
						
						{session ? (
							<div class="authenticated-action">
								<p>You are signed in as <strong>{session.user?.email}</strong>.</p>
								<form method="POST" action="?confirm=true" onsubmit="return confirm('ARE YOU ABSOLUTELY SURE? This action is irreversible and all your data will be PERMANENTLY DELETED.')">
									<button type="submit" class="btn btn-danger">
										Permanently Delete My Account
									</button>
								</form>
							</div>
						) : (
							<div class="unauthenticated-action">
								<p>To delete your account, you must first verify your identity by signing in.</p>
								<button id="verify-login-btn" class="btn btn-primary">
									Sign In to Verify Identity
								</button>
							</div>
						)}
					</section>

					<section>
						<h2>Other Ways to Delete</h2>
						<p>You can also initiate deletion through the mobile application:</p>
						
						<div class="steps">
							<div class="step">
								<span class="step-number">1</span>
								<p><strong>Open the App:</strong> Go to Settings > Account > Delete Account.</p>
							</div>
							<div class="step">
								<span class="step-number">2</span>
								<p><strong>Verification:</strong> Confirm your identity via Auth0.</p>
							</div>
						</div>
					</section>

					<section>
						<h2>Manual Deletion Request</h2>
						<p>If you are unable to access the application, email us at <a href="mailto:support@aebibtech.com">support@aebibtech.com</a> from your account email.</p>
					</section>
				</>
			)}
		</div>
	</div>
</Layout>

<script>
	const verifyLoginBtn = document.getElementById('verify-login-btn');
	if (verifyLoginBtn) {
		verifyLoginBtn.onclick = async () => {
			const { signIn } = await import('auth-astro/client');
			signIn('auth0');
		};
	}

	// Auto logout after successful deletion
	if (document.querySelector('.success-box')) {
		(async () => {
			const { signOut } = await import('auth-astro/client');
			
			// Clear local session
			await signOut();
			
			// Get Auth0 config from body data attributes (added by Layout.astro)
			const domain = document.body.dataset.auth0Domain;
			const clientId = document.body.dataset.auth0ClientId;
			const returnTo = document.body.dataset.baseUrl;
			
			if (domain && clientId && returnTo) {
				// Federated logout from Auth0
				window.location.href = `https://${domain}/v2/logout?client_id=${clientId}&returnTo=${encodeURIComponent(returnTo)}`;
			} else {
				// Fallback to home page
				window.location.href = '/';
			}
		})();
	}
</script>

