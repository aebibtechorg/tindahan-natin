---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.tsx';
import Features from '../components/Features.tsx';
---

<Layout title="Home">
	<Hero client:load />
	<Features client:visible />

	<section class="cta-banner">
		<div class="container">
			<div class="cta-content">
				<h2>Ready to modernize your store?</h2>
				<p>Join hundreds of store owners who are already growing their businesses with Tindahan Natin.</p>
				<button class="btn-accent">Download the App</button>
			</div>
		</div>
	</section>
</Layout>

<style>
	.cta-banner {
		padding: 6rem 0;
		background: #ffffff;
	}
	.cta-content {
		background: #1E88E5;
		color: white;
		padding: 4rem;
		border-radius: 32px;
		text-align: center;
		position: relative;
		overflow: hidden;
		box-shadow: 0 30px 60px -12px rgba(30, 136, 229, 0.3);
	}
	.cta-content h2 {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
	}
	.cta-content p {
		font-size: 1.25rem;
		margin-bottom: 2.5rem;
		opacity: 0.9;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}
	.btn-accent {
		background: var(--accent);
		color: #1a1a1a;
		border: none;
		padding: 1.25rem 3rem;
		border-radius: 14px;
		font-size: 1.1rem;
		font-weight: 800;
		cursor: pointer;
		transition: transform 0.2s;
	}
	.btn-accent:hover {
		transform: scale(1.05);
		background: #FFA000;
	}
</style>
